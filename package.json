{
  "name": "@philiprehberger/web-vitals",
  "version": "0.1.5",
  "description": "Web Vitals calculation utilities and client error capture",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "web-vitals",
    "performance",
    "metrics",
    "lcp",
    "cls",
    "inp",
    "fcp",
    "ttfb"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-web-vitals.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-web-vitals#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-web-vitals/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
