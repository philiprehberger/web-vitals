{
  "name": "@philiprehberger/web-vitals",
  "version": "0.1.2",
  "description": "Web Vitals calculation utilities and client error capture",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test src/__tests__/index.test.mjs"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "keywords": ["web-vitals", "performance", "metrics", "lcp", "cls", "inp", "fcp", "ttfb"],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-web-vitals.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-web-vitals#readme",
  "bugs": { "url": "https://github.com/philiprehberger/ts-web-vitals/issues" },
  "engines": { "node": ">=18.0.0" }
}
